---
import { policies } from '../data/site';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const asset = (path) => `${base}${path.replace(/^\//, '')}`;
---
<section class="shipping section" id="enviaments">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <p class="section-kicker">Informació útil</p>
        <h2>Enviaments i devolucions</h2>
      </div>
    </div>
    <div class="policy-grid">
      {policies.map((policy, index) => (
        <article class="policy-card reveal" style={`--delay:${index * 90}ms`}>
          <div class="policy-image">
            <img src={asset(policy.image)} alt={`${policy.title} Catarinetes`} loading="lazy" />
          </div>
          <div class="policy-content">
            <h3>{policy.title}</h3>
            <ul>
              {policy.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
