---
import { business } from '../data/site';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<footer class="footer">
  <div class="container footer-inner">
    <span>© 2026 {business.name}</span>
    <div class="footer-links">
      <a href={business.instagram} target="_blank" rel="noopener">Instagram</a>
      <a href="#inici">Tornar amunt</a>
    </div>
  </div>
</footer>
<a class="floating-call" href={`tel:${business.phone}`}>Trucar</a>
<script is:inline src={`${base}scripts/main.js`}></script>
